# ---------------------------------------------------------------------------
# Design Atlas — environment variables
# Copy this file to `.env.local` and fill in the values:
#   cp .env.example .env.local
# `.env.local` is gitignored and must never be committed.
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL / Neon) -----------------------------------------
# Connection string for your Postgres database.
# Get one for free at https://neon.tech (or use any Postgres instance).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Authentication (Neon Auth) -------------------------------------------
# Base URL of your Neon Auth instance.
NEON_AUTH_BASE_URL="https://your-neon-auth-instance.example.com"
# Secret used to sign session cookies. Generate one with:
#   openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET="change-me-with-a-32-byte-random-secret"

# --- File storage (Filebase / S3-compatible) ------------------------------
# S3-compatible storage for resource cover images.
# Filebase free tier works out of the box: https://filebase.com
FILES_BASE_ACCESS_KEY="your-access-key"
FILES_BASE_SECRET="your-secret-key"
FILES_BASE_BUCKET="your-bucket-name"
# Optional — defaults shown below.
# FILES_BASE_ENDPOINT="https://s3.filebase.io"
# FILES_BASE_REGION="auto"

# --- Site / SEO -----------------------------------------------------------
# Public base URL of the deployed site (used for sitemap, robots, metadata).
# Optional in development.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Seed (optional) ------------------------------------------------------
# Default admin created by `pnpm db:seed`.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_NAME="Admin"
# Number of fake resources generated by `pnpm db:seed:fake`.
# SEED_COUNT="120"
